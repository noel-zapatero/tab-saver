{
  "manifest_version": 3,
  "name": "tabsaver",
  "version": "0.1.0",
  "description": "Guardar tabs de Chrome en archivo local",
  "permissions": ["tabs", "windows"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}